# nbdpsy-text-to-video skill 凭据模板
# 复制为 .env 后填入真实值：cp .env.example .env
# .env 已被 .gitignore 忽略，绝不提交。
# 凭据由 agent 运行时【主动询问用户】填入，不硬编码进脚本/SKILL.md、不从项目 CLAUDE.md 读。

# ── 火山豆包大模型 TTS（高音质中文旁白；不配则自动回退 edge-tts 免费旁白）──
# 推荐：新版控制台单一 API Key（配了会优先生效，走 V3 单向流式接口）
# 获取：火山引擎控制台 → speech/new/setting/apikeys，生成一个 API Key
VOLC_TTS_API_KEY=

# 旧版双凭据（已有上面的 VOLC_TTS_API_KEY 可不填；走 V1 接口，官方已标"不推荐"，仅向后兼容）
# 获取：火山引擎控制台 → 语音技术 → 语音合成大模型，开通音色后取 APPID / Access Token
VOLC_TTS_APPID=
VOLC_TTS_ACCESS_TOKEN=
VOLC_TTS_CLUSTER=volcano_tts

# 可选：默认音色。留空则按引擎版本用各自默认——
# V3（配了 VOLC_TTS_API_KEY）默认「温柔淑女 2.0」zh_female_wenroushunv_uranus_bigtts；
# V1（旧版双凭据）默认「温柔淑女」zh_female_wenroushunv_mars_bigtts。
# 注意两套接口音色不通用：V3 只认 2.0 系（*_uranus_bigtts），V1 只认 *_mars_bigtts/*_moon_bigtts。
VOLC_TTS_VOICE=

# ── 火山豆包大模型 API（可选，进阶用；当前 TTS 产线用不到）──
VOLC_API_KEY=
VOLC_SECRET_KEY=

# ── 即梦 Dreamina（视频生成）不走 .env ──
# 在终端跑：dreamina login --headless  然后用抖音 App 扫码；
# 凭据存 ~/.dreamina_cli/，agent 无法代替扫码，只能引导你操作。
